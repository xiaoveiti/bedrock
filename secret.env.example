# bedrock secrets - Pushover credentials.
#
# Do NOT commit real values. On each server, place the real file at:
#     /opt/secrets/bedrock/secret.env      (root:root, chmod 600)
# (same convention as the Docker stacks under /opt/secrets/<app>/.env)
#
#   install -D -m600 secret.env.example /opt/secrets/bedrock/secret.env
#   # then edit /opt/secrets/bedrock/secret.env
#
# PUSHOVER_USER  = your user/group key (top of the pushover.net dashboard)
# PUSHOVER_TOKEN = an Application's API token (pushover.net -> Create Application)

PUSHOVER_USER=""
PUSHOVER_TOKEN=""

# -- SMTP relay (module 50-msmtp) - only the password lives here ---------------
SMTP_PASS=""
